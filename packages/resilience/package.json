{
  "name": "@centient/resilience",
  "version": "0.1.0",
  "description": "Zero-dependency resilience primitives: circuit breaker, token-bucket rate limiter, backoff-with-jitter, LRU/TTL/SWR cache, bounded-concurrency pool",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/centient-labs/centient-sdk.git",
    "directory": "packages/resilience"
  },
  "bugs": {
    "url": "https://github.com/centient-labs/centient-sdk/issues"
  },
  "homepage": "https://github.com/centient-labs/centient-sdk/tree/main/packages/resilience#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "centient",
    "resilience",
    "circuit-breaker",
    "rate-limiter",
    "backoff",
    "jitter",
    "cache",
    "lru",
    "concurrency"
  ],
  "author": "Owen Johnson",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "typescript": "^5.3.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
